# ==========================================
# SAEV Backend - Configurações de Ambiente
# ==========================================
# Este arquivo contém todas as variáveis de ambiente necessárias para o backend
# Para desenvolvimento local, copie este arquivo para .env e preencha os valores

# ------------------------------------------
# Servidor
# ------------------------------------------
# Porta onde o servidor NestJS irá rodar
PORT=3003

# ------------------------------------------
# Autenticação JWT
# ------------------------------------------
# Chave secreta para geração de tokens JWT
# IMPORTANTE: Use uma chave segura em produção (mínimo 32 caracteres)
JWT_SECRET=saev_secret_key_local_dev

# Tempo de expiração do token em segundos (28800 = 8 horas)
JWT_SECONDS_EXPIRE=28800

# ------------------------------------------
# Banco de Dados MySQL
# ------------------------------------------
# Ativar logs das queries SQL (útil para debug)
DB_LOGGING=true

# Host do banco de dados (localhost para desenvolvimento local)
DB_HOST=localhost

# Usuário do banco de dados
DB_USERNAME=root

# Senha do banco de dados (deve corresponder ao MYSQL_ROOT_PASSWORD do docker-compose.yml)
DB_PASSWORD=app

# Nome do banco de dados
DB_NAME=abc_saev

# Sincronizar automaticamente as entidades com o banco (usar apenas em desenvolvimento)
# ATENÇÃO: Em produção, use migrations ao invés de sync
DB_SYNC=true

# Executar migrations automaticamente ao iniciar (false recomendado para desenvolvimento)
DB_MIGRATIONS_RUN=false

# Porta do banco de dados
DB_PORT=3306

# ------------------------------------------
# Autenticação HTTP Basic (APIs Externas)
# ------------------------------------------
# Credenciais para integração com APIs externas
HTTP_BASIC_USER_HERBY=
HTTP_BASIC_PASS_HERBY=
USER_SAEV_EDLER=
HTTP_BASIC_USER_EDLER=
HTTP_BASIC_PASS_EDLER=
HTTP_BASIC_USER_IMPORT_STUDENT=
HTTP_BASIC_PASS_IMPORT_STUDENT=

# ------------------------------------------
# Configurações de E-mail (SMTP)
# ------------------------------------------
# Servidor SMTP para envio de e-mails
MAIL_HOST=
MAIL_PORT=
MAIL_SERVICE=
MAIL_USER=
MAIL_PASS=
MAIL_REPLY=

# ------------------------------------------
# SendGrid (Alternativa ao SMTP)
# ------------------------------------------
# API Key do SendGrid (se usar SendGrid ao invés de SMTP)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_WEBHOOK_VERIFICATION_KEY=

# ------------------------------------------
# Twilio (WhatsApp/SMS)
# ------------------------------------------
# Credenciais do Twilio para envio de mensagens
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_MESSAGING_SERVICE_SID=

# ------------------------------------------
# URLs da Aplicação
# ------------------------------------------
# URL do frontend (para configuração de CORS e redirecionamentos)
FRONT_APP_URL=http://localhost:3000

# URL do backend (para configuração de links em e-mails, etc)
HOST_APP_URL=http://localhost:3003